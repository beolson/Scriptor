{
  "enabledPlugins": {
    "skill-creator@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$CLAUDE_TOOL_INPUT\" | grep -qE '^\\s*(node|npm|pnpm|npx)\\b'; then echo 'Blocked: use bun instead of node/npm/pnpm' >&2; exit 2; fi"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bun run --cwd $(git rev-parse --show-toplevel) pre:stop || exit 2"
          }
        ]
      }
    ]
  }
}
