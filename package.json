{
	"name": "scriptor",
	"type": "module",
	"private": true,
	"packageManager": "bun@1.3.11",
	"workspaces": [
		"20_Applications/*",
		"25_UI_Components/*",
		"30_Services/*",
		"50_IFX/*"
	],
	"scripts": {
		"build": "turbo run build",
		"dev": "turbo watch dev",
		"check": "biome check --write . --max-diagnostics 100",
		"lint": "biome lint --write .",
		"format": "biome format --write .",
		"typecheck": "turbo run typecheck",
		"test:unit": "turbo run test:unit",
		"test:e2e": "turbo run test:e2e",
		"db:dev": "docker compose -f 40_Infrastructure/docker-compose.dev.yml up -d",
		"shadcn": "bun --cwd 20_Applications/agent-sap shadcn",
		"db:migrate": "bun --cwd 20_Applications/agent-sap run db:migrate",
		"pre:stop": "bun run lint && bun run check && bun run typecheck"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.8",
		"@types/bun": "^1.3.11",
		"turbo": "^2.8.20",
		"typescript": "^6.x"
	}
}
