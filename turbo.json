{
	"$schema": "https://turbo.build/schema.json",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": ["dist/**", ".next/**", "out/**", "../dist/**"]
		},
		"lint": {
			"dependsOn": []
		},
		"format": {
			"dependsOn": []
		},
		"typecheck": {
			"dependsOn": ["^build"]
		},
		"test:unit": {
			"dependsOn": []
		},
		"test:e2e": {
			"dependsOn": ["build"]
		}
	}
}
