{
	"$schema": "https://turbo.build/schema.json",
	"ui": "stream",
	"globalDependencies": ["biome.json"],
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"inputs": [
				"$TURBO_DEFAULT$",
				"../../scripts/**",
				"!README.md",
				"!**/*.test.ts",
				"!**/*.spec.ts"
			],
			"outputs": ["dist/**", ".next/**", "out/**"]
		},
		"dev": {
			"cache": false,
			"persistent": true,
			"interruptible": true
		},
		"lint": {
			"inputs": ["$TURBO_DEFAULT$", "!README.md"]
		},
		"typecheck": {
			"inputs": ["$TURBO_DEFAULT$", "!README.md"]
		},
		"format": {},
		"test:unit": {
			"inputs": ["$TURBO_DEFAULT$", "!README.md"]
		},
		"test:e2e": {
			"dependsOn": ["^build", "build"],
			"cache": false
		}
	}
}
