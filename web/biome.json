{
	"$schema": "https://biomejs.dev/schemas/2.4.6/schema.json",
	"extends": ["../biome.json"],
	"vcs": {
		"useIgnoreFile": false
	},
	"files": {
		"includes": [
			"**",
			"!.next",
			"!out",
			"!coverage",
			"!test-results",
			"!playwright-report"
		]
	},
	"css": {
		"parser": {
			"cssModules": true,
			"tailwindDirectives": true
		},
		"formatter": {
			"enabled": true,
			"indentStyle": "tab"
		}
	}
}
